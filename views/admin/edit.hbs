{{> header}}
<div class="container">
  <div class="card">
    <h2 class="card-title" style="margin-bottom:1.5rem">Modifier le Quiz</h2>
    <form method="POST" action="/admin/edit/{{quiz.id}}">
      <div class="form-group">
        <label>Question</label>
        <input type="text" name="question" class="form-control" required value="{{quiz.question}}">
      </div>
      <div class="form-group">
        <label>Options</label>
        <small>Une option par ligne</small>
        <textarea name="options" class="form-control" required>{{quiz.optionsText}}</textarea>
      </div>
      <div class="form-group">
        <label>Reponse(s) correcte(s)</label>
        <small>Indices des bonnes reponses (commence a 0), separes par des virgules.</small>
        <input type="text" name="answers" class="form-control" required value="{{quiz.answersText}}">
      </div>
      <div class="form-group">
        <label>Temps (secondes)</label>
        <input type="number" name="times" class="form-control" value="{{quiz.times}}" min="5" max="300">
      </div>
      <div style="display:flex;gap:0.75rem">
        <button type="submit" class="btn btn-primary">Enregistrer</button>
        <a href="/admin" class="btn btn-outline">Annuler</a>
      </div>
    </form>
  </div>
</div>
{{> footer}}
