{{> header}}
<div class="container">
  <div class="card results-card">
    <h2 class="card-title">Resultats</h2>
    <div class="score-circle">
      {{participant.score}}/{{total}}
      <small>{{percentage participant.score total}}%</small>
    </div>
    <p class="score-label">
      Merci {{participant.name}} pour votre participation !
    </p>
    {{#if (eq participant.score total)}}
      <p style="color:#27ae60;font-weight:600;margin-bottom:1.5rem">Excellent ! Score parfait !</p>
    {{else}}
      {{#if (eq participant.score 0)}}
        <p style="color:#e74c3c;font-weight:600;margin-bottom:1.5rem">N'hesitez pas a retenter votre chance !</p>
      {{else}}
        <p style="color:#e67e22;font-weight:600;margin-bottom:1.5rem">Bien joue ! Vous pouvez faire encore mieux.</p>
      {{/if}}
    {{/if}}
    <a href="/quiz" class="btn btn-primary">Rejouer</a>
  </div>
</div>
{{> footer}}
