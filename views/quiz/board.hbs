{{> header}}
<div class="container">
  <div class="board-header">
    <h2>Bonjour {{participant.name}} 👋</h2>
    <p>Choisissez un numéro pour découvrir la question cachée derrière !</p>
    <p class="remaining-badge">{{remaining}} participation{{#unless (eq remaining 1)}}s{{/unless}} restante{{#unless (eq remaining 1)}}s{{/unless}} aujourd'hui</p>
  </div>

  <div class="numbers-grid">
    {{#each numbers}}
    <a href="{{#if this.answered}}#{{else}}/quiz/play/{{../participant.id}}/{{@index}}{{/if}}"
       class="number-cell {{#if this.answered}}answered{{/if}}">
      <span class="number-value">{{this.number}}</span>
      {{#if this.answered}}
      <span class="number-check">✓</span>
      {{/if}}
    </a>
    {{/each}}
  </div>
</div>
{{> footer}}
