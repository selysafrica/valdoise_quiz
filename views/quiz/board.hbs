{{> header}}
<div class="container">
  {{#if quotaExceeded}}
  <div class="card" style="text-align:center;max-width:500px;margin:3.5rem auto">
    <div style="font-size:3rem;margin-bottom:0.8rem">⏰</div>
    <h2 style="margin-bottom:0.5rem">Quota atteint !</h2>
    <p style="color:rgba(255,255,255,0.65);margin-bottom:0.5rem">
      Vous avez utilisé vos <strong>{{dailyQuota}}</strong> participations du jour.
    </p>
    <p style="color:rgba(255,255,255,0.5);margin-bottom:1.5rem;font-size:0.92rem">
      Revenez demain pour continuer à jouer !
    </p>
    <a href="/quiz" class="btn btn-primary">Retour</a>
  </div>
  {{else}}
  <div class="board-header">
    <h2>Bonjour {{participant.name}} 👋</h2>
    <p>Choisissez un numéro pour découvrir la question cachée derrière !</p>
    <p class="remaining-badge">{{remaining}} participation{{#unless (eq remaining 1)}}s{{/unless}} restante{{#unless (eq remaining 1)}}s{{/unless}} aujourd'hui</p>
  </div>

  <div class="numbers-grid">
    {{#each numbers}}
    <a href="{{#if this.answered}}#{{else}}/quiz/play/{{../participant.id}}/{{@index}}{{/if}}"
       class="number-cell {{#if this.answered}}answered{{/if}}">
      <span class="number-value">{{this.number}}</span>
      {{#if this.answered}}
      <span class="number-check">✓</span>
      {{/if}}
    </a>
    {{/each}}
  </div>
  {{/if}}
</div>
{{> footer}}
