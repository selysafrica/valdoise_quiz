{{#if finished}}
{{> header}}
<div class="container">
  <div class="card results-card">
    <h2 class="card-title">Quiz terminé !</h2>
    <div class="score-circle">
      {{participant.score}}/{{total}}
      <small>{{percentage participant.score total}}%</small>
    </div>
    <p class="score-label">
      {{#if (eq participant.score total)}}
        Parfait ! Vous avez tout bon !
      {{else}}
        {{#if (eq participant.score 0)}}
          Pas de chance cette fois. Retentez votre chance !
        {{else}}
          Bien joué ! Continuez à apprendre.
        {{/if}}
      {{/if}}
    </p>
    <a href="/quiz" class="btn btn-primary">Recommencer</a>
  </div>
</div>
{{> footer}}
{{else}}
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Question {{add currentIndex 1}} - Pharmacie Val d'Oise</title>
  <link rel="icon" type="image/png" href="/public/images/logo.png">
  <link rel="stylesheet" href="/public/css/style.css">
</head>
<body>
  <div class="quiz-topbar">
    <div class="brand">
      <img src="/public/images/logo.png" alt="Pharmacie Val d'Oise">
      <span>Pharmacie Val d'Oise</span>
    </div>
    <div class="quiz-progress">
      <div class="label">Question {{add currentIndex 1}} / {{totalQuizzes}}</div>
      <div class="bar"><div class="fill" style="width: {{percentage currentIndex totalQuizzes}}%"></div></div>
    </div>
    <div class="timer-ring" id="timerRing">
      <svg viewBox="0 0 62 62">
        <circle class="track" cx="31" cy="31" r="27"></circle>
        <circle class="arc" id="timerArc" cx="31" cy="31" r="27"></circle>
      </svg>
      <span class="num" id="timer">{{quiz.times}}</span>
    </div>
  </div>

  <div class="quiz-container">
    <div class="question-card">
      <span class="q-badge">Q{{add currentIndex 1}}</span>
      <h2 class="quiz-question">{{quiz.question}}</h2>
      <p class="quiz-hint" id="hint"></p>
    </div>

    <div class="options-list" id="options">
      {{#each quiz.options}}
      <button class="option-btn" data-index="{{@index}}" onclick="selectOption(this, {{@index}})">
        <span class="option-letter">{{#if (eq @index 0)}}A{{/if}}{{#if (eq @index 1)}}B{{/if}}{{#if (eq @index 2)}}C{{/if}}{{#if (eq @index 3)}}D{{/if}}{{#if (eq @index 4)}}E{{/if}}{{#if (eq @index 5)}}F{{/if}}{{#if (eq @index 6)}}G{{/if}}</span>
        <span>{{this}}</span>
      </button>
      {{/each}}
    </div>

    <div id="feedback" style="display:none"></div>

    <div style="text-align:center">
      <button id="validateBtn" class="btn btn-primary" onclick="validateAnswer()" style="display:none">
        Valider ma réponse
      </button>
      <button id="nextBtn" class="btn btn-primary" onclick="nextQuestion()" style="display:none">
        Question suivante &rarr;
      </button>
    </div>
  </div>

<script>
  var quiz = {{{json quiz}}};
  var participantId = {{participant.id}};
  var currentIndex = {{currentIndex}};
  var nextIndex = {{nextIndex}};
  var totalQuizzes = {{totalQuizzes}};
  var timeLeft = quiz.times;
  var selectedOptions = [];
  var answered = false;
  var timerInterval;

  var timerEl = document.getElementById('timer');
  var timerRing = document.getElementById('timerRing');
  var timerArc = document.getElementById('timerArc');
  var validateBtn = document.getElementById('validateBtn');
  var nextBtn = document.getElementById('nextBtn');
  var feedbackEl = document.getElementById('feedback');
  var hintEl = document.getElementById('hint');

  var CIRC = 2 * Math.PI * 27;
  timerArc.style.strokeDasharray = CIRC;
  timerArc.style.strokeDashoffset = 0;

  if (quiz.answers.length > 1) {
    hintEl.textContent = 'Plusieurs réponses possibles — sélectionnez toutes les bonnes réponses.';
  }

  function updateRing() {
    var ratio = timeLeft / quiz.times;
    timerArc.style.strokeDashoffset = CIRC * (1 - ratio);
    if (ratio <= 0.17) {
      timerRing.className = 'timer-ring danger';
    } else if (ratio <= 0.35) {
      timerRing.className = 'timer-ring warning';
    }
  }

  function startTimer() {
    timerInterval = setInterval(function() {
      timeLeft--;
      timerEl.textContent = timeLeft;
      updateRing();
      if (timeLeft <= 0) {
        clearInterval(timerInterval);
        timeUp();
      }
    }, 1000);
  }

  function selectOption(btn, index) {
    if (answered) return;

    var idx = selectedOptions.indexOf(index);
    if (idx > -1) {
      selectedOptions.splice(idx, 1);
      btn.classList.remove('selected');
    } else {
      if (quiz.answers.length === 1) {
        selectedOptions = [index];
        document.querySelectorAll('.option-btn').forEach(function(b) {
          b.classList.remove('selected');
        });
        btn.classList.add('selected');
      } else {
        selectedOptions.push(index);
        btn.classList.add('selected');
      }
    }

    validateBtn.style.display = selectedOptions.length > 0 ? '' : 'none';
  }

  function validateAnswer() {
    if (answered || selectedOptions.length === 0) return;
    answered = true;
    clearInterval(timerInterval);

    fetch('/quiz/answer/' + participantId + '/' + currentIndex, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ selected: selectedOptions })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      showResult(data.correct, data.correctAnswers, data.selected);
    });
  }

  function timeUp() {
    answered = true;
    validateBtn.style.display = 'none';

    fetch('/quiz/answer/' + participantId + '/' + currentIndex, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ selected: [] })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      showResult(false, data.correctAnswers, [], true);
    });
  }

  function showResult(isCorrect, correctAnswers, selected, isTimeout) {
    var buttons = document.querySelectorAll('.option-btn');
    buttons.forEach(function(btn) {
      var idx = parseInt(btn.getAttribute('data-index'));
      btn.classList.add('disabled');
      btn.classList.remove('selected');

      if (correctAnswers.includes(idx)) {
        btn.classList.add('correct');
        var icon = document.createElement('span');
        icon.className = 'result-icon';
        icon.textContent = '✓';
        btn.appendChild(icon);
      } else if (selected.includes(idx)) {
        btn.classList.add('wrong');
        var icon = document.createElement('span');
        icon.className = 'result-icon';
        icon.textContent = '✗';
        btn.appendChild(icon);
      } else {
        btn.classList.add('dimmed');
      }
    });

    feedbackEl.style.display = '';
    if (isTimeout) {
      feedbackEl.innerHTML = '<div class="feedback-msg timeout">&#9200; Temps écoulé ! Voici la bonne réponse.</div>';
    } else if (isCorrect) {
      feedbackEl.innerHTML = '<div class="feedback-msg correct">&#10003; Bonne réponse !</div>';
    } else {
      feedbackEl.innerHTML = '<div class="feedback-msg wrong">&#10007; Mauvaise réponse. Voici la bonne réponse.</div>';
    }

    validateBtn.style.display = 'none';
    nextBtn.style.display = '';
  }

  function nextQuestion() {
    if (nextIndex >= totalQuizzes) {
      window.location.href = '/quiz/results/' + participantId;
    } else {
      window.location.href = '/quiz/play/' + participantId + '/' + nextIndex;
    }
  }

  startTimer();
</script>
</body>
</html>
{{/if}}
