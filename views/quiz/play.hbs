{{#if error}}
{{> header}}
<div class="container">
  <div class="card" style="text-align:center">
    <h2>{{error}}</h2>
    <a href="/quiz" class="btn btn-primary" style="margin-top:1rem">Retour</a>
  </div>
</div>
{{> footer}}
{{else if quotaExceeded}}
{{> header}}
<div class="container">
  <div class="card" style="text-align:center;max-width:500px;margin:3.5rem auto">
    <div style="font-size:3rem;margin-bottom:0.8rem">⏰</div>
    <h2 style="margin-bottom:0.5rem">Quota atteint !</h2>
    <p style="color:rgba(255,255,255,0.65);margin-bottom:1.5rem">Revenez demain pour continuer à jouer !</p>
    <a href="/quiz" class="btn btn-primary">Retour</a>
  </div>
</div>
{{> footer}}
{{else if alreadyAnswered}}
{{> header}}
<div class="container">
  <div class="card" style="text-align:center">
    <h2>Numéro {{number}} déjà répondu !</h2>
    <p style="color:rgba(255,255,255,0.65);margin:1rem 0">Vous avez déjà répondu à cette question. Choisissez un autre numéro.</p>
    <a href="/quiz/board/{{participant.id}}" class="btn btn-primary">Retourner</a>
  </div>
</div>
{{> footer}}
{{else}}
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Question N°{{number}} - Pharmacie Val d'Oise</title>
  <link rel="icon" type="image/png" href="/public/images/logo.png">
  <link rel="stylesheet" href="/public/css/style.css">
</head>
<body>
  <div class="quiz-topbar">
    <div class="brand">
      <img src="/public/images/logo.png" alt="Pharmacie Val d'Oise">
      <span>Pharmacie Val d'Oise</span>
    </div>
    <div class="number-badge-top">N°{{number}}</div>
  </div>

  <div class="quiz-container">
    <div class="question-card">
      <span class="q-badge">Question N°{{number}}</span>
      <h2 class="quiz-question">{{quiz.question}}</h2>
      <p class="quiz-hint" id="hint"></p>
    </div>

    <div class="options-list" id="options">
      {{#each quiz.options}}
      <button class="option-btn" data-index="{{@index}}" onclick="selectOption(this, {{@index}})">
        <span class="option-letter">{{#if (eq @index 0)}}A{{/if}}{{#if (eq @index 1)}}B{{/if}}{{#if (eq @index 2)}}C{{/if}}{{#if (eq @index 3)}}D{{/if}}{{#if (eq @index 4)}}E{{/if}}{{#if (eq @index 5)}}F{{/if}}{{#if (eq @index 6)}}G{{/if}}</span>
        <span>{{this}}</span>
      </button>
      {{/each}}
    </div>

    <div style="text-align:center">
      <button id="validateBtn" class="btn btn-primary" onclick="validateAnswer()" style="display:none">
        Valider ma réponse
      </button>
    </div>

    <div id="resultOverlay" class="result-overlay" style="display:none"></div>
  </div>

<script>
  var quiz = {{{json quiz}}};
  var participantId = {{participant.id}};
  var numberIndex = {{numberIndex}};
  var selectedOptions = [];
  var answered = false;

  var validateBtn = document.getElementById('validateBtn');
  var hintEl = document.getElementById('hint');

  if (quiz.answers.length > 1) {
    hintEl.textContent = 'Plusieurs réponses possibles — sélectionnez toutes les bonnes réponses.';
  }

  function selectOption(btn, index) {
    if (answered) return;

    var idx = selectedOptions.indexOf(index);
    if (idx > -1) {
      selectedOptions.splice(idx, 1);
      btn.classList.remove('selected');
    } else {
      if (quiz.answers.length === 1) {
        selectedOptions = [index];
        document.querySelectorAll('.option-btn').forEach(function(b) {
          b.classList.remove('selected');
        });
        btn.classList.add('selected');
      } else {
        selectedOptions.push(index);
        btn.classList.add('selected');
      }
    }

    validateBtn.style.display = selectedOptions.length > 0 ? '' : 'none';
  }

  function validateAnswer() {
    if (answered || selectedOptions.length === 0) return;
    answered = true;

    fetch('/quiz/answer/' + participantId + '/' + numberIndex, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ selected: selectedOptions })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      showResult(data.correct, data.correctAnswers, data.selected);
    });
  }

  function showResult(isCorrect, correctAnswers, selected) {
    var buttons = document.querySelectorAll('.option-btn');
    buttons.forEach(function(btn) {
      var idx = parseInt(btn.getAttribute('data-index'));
      btn.classList.add('disabled');
      btn.classList.remove('selected');

      if (correctAnswers.includes(idx)) {
        btn.classList.add('correct');
        var icon = document.createElement('span');
        icon.className = 'result-icon';
        icon.textContent = '✓';
        btn.appendChild(icon);
      } else if (selected.includes(idx)) {
        btn.classList.add('wrong');
        var icon = document.createElement('span');
        icon.className = 'result-icon';
        icon.textContent = '✗';
        btn.appendChild(icon);
      } else {
        btn.classList.add('dimmed');
      }
    });

    validateBtn.style.display = 'none';

    var overlay = document.getElementById('resultOverlay');
    overlay.style.display = '';

    if (isCorrect) {
      overlay.innerHTML =
        '<div class="result-card result-success">' +
          '<div class="result-emoji">🎉</div>' +
          '<h2>FÉLICITATIONS !</h2>' +
          '<p>VOUS AVEZ LA BONNE RÉPONSE</p>' +
          '<p class="result-sub">Veuillez vous rapprocher d\'un agent pour récupérer votre cadeau</p>' +
          '<a href="/quiz/board/' + participantId + '" class="btn btn-primary">Retourner</a>' +
        '</div>';
    } else {
      overlay.innerHTML =
        '<div class="result-card result-fail">' +
          '<div class="result-emoji">😔</div>' +
          '<h2>DOMMAGE !</h2>' +
          '<p>Ce n\'est pas la bonne réponse</p>' +
          '<p class="result-sub">La bonne réponse est indiquée en vert ci-dessus</p>' +
          '<a href="/quiz/board/' + participantId + '" class="btn btn-primary">Retourner</a>' +
        '</div>';
    }
  }
</script>
</body>
</html>
{{/if}}
