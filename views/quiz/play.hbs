{{> header}}
{{#if finished}}
<div class="container">
  <div class="card results-card">
    <h2 class="card-title">Quiz termine !</h2>
    <div class="score-circle">
      {{participant.score}}/{{total}}
      <small>{{percentage participant.score total}}%</small>
    </div>
    <p class="score-label">
      {{#if (eq participant.score total)}}
        Parfait ! Vous avez tout bon !
      {{else}}
        {{#if (eq participant.score 0)}}
          Pas de chance cette fois. Retentez votre chance !
        {{else}}
          Bien joue ! Continuez a apprendre.
        {{/if}}
      {{/if}}
    </p>
    <a href="/quiz" class="btn btn-primary">Recommencer</a>
  </div>
</div>
{{else}}

<div class="quiz-container">
  <div class="progress-bar-wrap">
    <div class="progress-bar" style="width: {{percentage currentIndex totalQuizzes}}%"></div>
  </div>

  <p class="quiz-number">Question {{add currentIndex 1}} sur {{totalQuizzes}}</p>

  <h2 class="quiz-question">{{quiz.question}}</h2>

  <div class="timer-wrap">
    <div class="timer-circle" id="timer">{{quiz.times}}</div>
  </div>

  <div class="options-list" id="options">
    {{#each quiz.options}}
    <button class="option-btn" data-index="{{@index}}" onclick="selectOption(this, {{@index}})">
      <span class="option-letter">{{#if (eq @index 0)}}A{{/if}}{{#if (eq @index 1)}}B{{/if}}{{#if (eq @index 2)}}C{{/if}}{{#if (eq @index 3)}}D{{/if}}{{#if (eq @index 4)}}E{{/if}}{{#if (eq @index 5)}}F{{/if}}</span>
      <span>{{this}}</span>
    </button>
    {{/each}}
  </div>

  <div id="feedback" style="display:none"></div>

  <div style="text-align:center">
    <button id="validateBtn" class="btn btn-primary" onclick="validateAnswer()" style="display:none">
      Valider ma reponse
    </button>
    <button id="nextBtn" class="btn btn-primary" onclick="nextQuestion()" style="display:none">
      Question suivante
    </button>
  </div>
</div>

<script>
  var quiz = {{{json quiz}}};
  var participantId = {{participant.id}};
  var currentIndex = {{currentIndex}};
  var nextIndex = {{nextIndex}};
  var totalQuizzes = {{totalQuizzes}};
  var timeLeft = quiz.times;
  var selectedOptions = [];
  var answered = false;
  var timerInterval;

  var timerEl = document.getElementById('timer');
  var validateBtn = document.getElementById('validateBtn');
  var nextBtn = document.getElementById('nextBtn');
  var feedbackEl = document.getElementById('feedback');

  function startTimer() {
    timerInterval = setInterval(function() {
      timeLeft--;
      timerEl.textContent = timeLeft;

      if (timeLeft <= 10 && timeLeft > 5) {
        timerEl.className = 'timer-circle warning';
      } else if (timeLeft <= 5) {
        timerEl.className = 'timer-circle danger';
      }

      if (timeLeft <= 0) {
        clearInterval(timerInterval);
        timeUp();
      }
    }, 1000);
  }

  function selectOption(btn, index) {
    if (answered) return;

    var idx = selectedOptions.indexOf(index);
    if (idx > -1) {
      selectedOptions.splice(idx, 1);
      btn.classList.remove('selected');
    } else {
      if (quiz.answers.length === 1) {
        selectedOptions = [index];
        document.querySelectorAll('.option-btn').forEach(function(b) {
          b.classList.remove('selected');
        });
        btn.classList.add('selected');
      } else {
        selectedOptions.push(index);
        btn.classList.add('selected');
      }
    }

    validateBtn.style.display = selectedOptions.length > 0 ? '' : 'none';
  }

  function validateAnswer() {
    if (answered || selectedOptions.length === 0) return;
    answered = true;
    clearInterval(timerInterval);

    fetch('/quiz/answer/' + participantId + '/' + currentIndex, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ selected: selectedOptions })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      showResult(data.correct, data.correctAnswers, data.selected);
    });
  }

  function timeUp() {
    answered = true;
    validateBtn.style.display = 'none';

    fetch('/quiz/answer/' + participantId + '/' + currentIndex, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ selected: [] })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      showResult(false, data.correctAnswers, [], true);
    });
  }

  function showResult(isCorrect, correctAnswers, selected, isTimeout) {
    var buttons = document.querySelectorAll('.option-btn');
    buttons.forEach(function(btn) {
      var idx = parseInt(btn.getAttribute('data-index'));
      btn.classList.add('disabled');
      btn.classList.remove('selected');

      if (correctAnswers.includes(idx)) {
        btn.classList.add('correct');
        btn.querySelector('.result-icon')?.remove();
        var icon = document.createElement('span');
        icon.className = 'result-icon';
        icon.textContent = '✓';
        btn.appendChild(icon);
      }

      if (selected.includes(idx) && !correctAnswers.includes(idx)) {
        btn.classList.add('wrong');
        btn.querySelector('.result-icon')?.remove();
        var icon = document.createElement('span');
        icon.className = 'result-icon';
        icon.textContent = '✗';
        btn.appendChild(icon);
      }
    });

    feedbackEl.style.display = '';
    if (isTimeout) {
      feedbackEl.innerHTML = '<div class="feedback-msg timeout">Temps ecoule ! Voici la bonne reponse.</div>';
    } else if (isCorrect) {
      feedbackEl.innerHTML = '<div class="feedback-msg correct">Bonne reponse !</div>';
    } else {
      feedbackEl.innerHTML = '<div class="feedback-msg wrong">Mauvaise reponse. Voici la bonne reponse.</div>';
    }

    validateBtn.style.display = 'none';
    nextBtn.style.display = '';
  }

  function nextQuestion() {
    if (nextIndex >= totalQuizzes) {
      window.location.href = '/quiz/results/' + participantId;
    } else {
      window.location.href = '/quiz/play/' + participantId + '/' + nextIndex;
    }
  }

  startTimer();
</script>
{{/if}}
{{> footer}}
